{
  "name": "seo-style-checker",
  "version": "1.0.0",
  "description": "B2B SEO & Style Checker - Deployment Version",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "npm install && cd frontend && npm install && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "postinstall": "cd frontend && npm install",
    "dev": "node server.js"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "sharp": "^0.34.5"
  }
}
